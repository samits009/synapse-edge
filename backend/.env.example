# ============================================================================
# SynapseEdge Backend — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# Vertex AI
VERTEX_AI_MODEL=text-embedding-005
VERTEX_AI_EMBEDDING_DIMENSIONS=768

# Cloud SQL (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/synapse_edge
# For Cloud SQL via Unix socket:
# DATABASE_URL=postgresql+asyncpg://postgres:password@/synapse_edge?host=/cloudsql/project:region:instance

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:3000,https://synapse-edge.web.app

# Vector Matching
DEFAULT_MATCH_LIMIT=5
SIMILARITY_THRESHOLD=0.5
